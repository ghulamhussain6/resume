version: '3.8'

services:
  # 1. Nginx Proxy
  proxy:
    image: nginx:alpine
    container_name: ${PROXY_CONTAINER}
    ports:
      - "80:80"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      - resume-app-professional

  # 2. Node.js App (The Professional Build)
  resume-app-professional:
    image: ${IMAGE_NAME}:${IMAGE_TAG}
    build:
      context: .
      dockerfile: Dockerfile
    container_name: ${APP_CONTAINER}
    environment:
      - PORT=${APP_PORT}
      - MONGO_URI=${MONGO_URI}
    depends_on:
      - mongodb-service

  # 3. MongoDB
  mongodb-service:
    image: mongo:4.4
    container_name: ${DB_CONTAINER}
    volumes:
      - ./data/mongodb:/data/db
